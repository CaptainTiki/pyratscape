[connection signal="pressed" from="CenterPanel/MarginContainer/VBoxContainer/ButtonRow/BackButton" to="." method="_on_back_button_pressed"]
[connection signal="pressed" from="CenterPanel/MarginContainer/VBoxContainer/ButtonRow/DeployButton" to="." method="_on_deploy_button_pressed"]
